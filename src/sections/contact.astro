            </svg>
            www.inadaptado.cl
        </a>

        <a class="link" href="mailto:nicolas@inadaptado.cl" aria-label="Enviar email a nicolas@inadaptado.cl">
            <svg
            xmlns="http://www.w3.org/2000/svg"
            width="40"
            height="40"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
