---
import nicoProfile from '../data/nico-profile.json';

const API_KEY = import.meta.env.PUBLIC_GROQ_API_KEY || '';
const profileData = JSON.stringify(nicoProfile);
---

<section id="ai-chat" class="history chatbot-section">
    <h2 class="heading">
        <svg
            xmlns="http://www.w3.org/2000/svg"
            width="40"
            height="40"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
        >
            <path d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z" />
            <path d="M18.25 6.5 18 7.5l-.25-1a2 2 0 0 0-1.25-1.25L15.5 5l1-.25a2 2 0 0 0 1.25-1.25L18 2.5l.25 1a2 2 0 0 0 1.25 1.25l1 .25-1 .25a2 2 0 0 0-1.25 1.25Z" />
        </svg>
        Habla con mi versión AI
    </h2>

    <div class="ai-assistant">
        <div class="ai-brain">
            <div class="brain-ring"></div>
            <div class="brain-ring"></div>
            <div class="brain-ring"></div>
            <div class="brain-core">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z" />
                </svg>
            </div>
        </div>

        <div class="ai-response-area" id="ai-response-area">
            <p class="ai-response" id="ai-response">Pregúntame lo que quieras sobre Nico: su experiencia, habilidades, o por qué deberías trabajar con él.</p>
        </div>

        <div class="ai-loader" id="ai-loader" hidden>
            <div class="loader-dots">
                <span></span>
                <span></span>
                <span></span>
            </div>
            <p class="loader-text">Pensando...</p>
        </div>

        <div class="ai-suggestions" id="ai-suggestions">
            <button class="suggestion-chip" data-question="¿Cuál es tu experiencia profesional?">
                <span class="chip-icon">💼</span>
                <span>Experiencia</span>
            </button>
            <button class="suggestion-chip" data-question="¿Qué habilidades técnicas tienes?">
                <span class="chip-icon">🛠️</span>
                <span>Habilidades</span>
            </button>
            <button class="suggestion-chip" data-question="¿Por qué debería contratarte?">
                <span class="chip-icon">🚀</span>
                <span>Contratarte</span>
            </button>
        </div>

        <form class="ai-input-wrapper" id="chat-form">
            <div class="ai-input-container">
                <input 
                    type="text" 
                    id="user-input" 
                    placeholder="Escribe tu pregunta..." 
                    autocomplete="off"
                    aria-label="Escribe tu mensaje"
                />
                <button type="submit" aria-label="Enviar mensaje" id="send-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14" />
                        <path d="m12 5 7 7-7 7" />
                    </svg>
                </button>
            </div>
        </form>

        <p class="ai-footer">
            <span class="pulse-dot"></span>
            Nico AI · Siempre disponible
        </p>
    </div>
</section>

<script is:inline define:vars={{ profileData, API_KEY }}>
(function() {
    const GROQ_URL = 'https://api.groq.com/openai/v1/chat/completions';
    const nicoProfile = JSON.parse(profileData);
    
    const systemPrompt = 'Eres Nico AI, la versión digital de Nicolás Gaitán. Tu objetivo es representarlo de manera auténtica, responder preguntas sobre su experiencia y convencer a potenciales clientes o empleadores de trabajar con él.\n\nINFORMACIÓN DE NICO:\n' + JSON.stringify(nicoProfile, null, 2) + '\n\nINSTRUCCIONES:\n- Responde en primera persona como si fueras Nico\n- Sé cercano, entusiasta y profesional\n- Destaca siempre los puntos fuertes y la propuesta de valor\n- Si preguntan por algo que no sabes, sugiere que contacten directamente a Nico\n- Respuestas concisas pero completas (máx 2-3 párrafos)\n- Usa emojis ocasionalmente para ser más cercano\n- Si preguntan por qué contratarlo, sé convincente pero genuino\n- Puedes recomendar que visiten inadaptado.cl o lo contacten directamente\n- Responde siempre en español a menos que te hablen en otro idioma';

    let conversationHistory = [];
    let isLoading = false;
    let lastMessageTime = 0;
    const COOLDOWN_MS = 2000;

    const responseArea = document.getElementById('ai-response-area');
    const responseText = document.getElementById('ai-response');
    const loader = document.getElementById('ai-loader');
    const suggestions = document.getElementById('ai-suggestions');
    const chatForm = document.getElementById('chat-form');
    const userInput = document.getElementById('user-input');
    const sendBtn = document.getElementById('send-btn');
    const suggestionChips = document.querySelectorAll('.suggestion-chip');
    const aiBrain = document.querySelector('.ai-brain');

    function getCooldownRemaining() {
        const elapsed = Date.now() - lastMessageTime;
        return Math.max(0, COOLDOWN_MS - elapsed);
    }

    function formatCooldown(ms) {
        return Math.ceil(ms / 1000);
    }

    function setLoading(loading) {
        isLoading = loading;
        sendBtn.disabled = loading;
        userInput.disabled = loading;
        
        if (loading) {
            loader.hidden = false;
            responseArea.classList.add('hidden');
            suggestions.classList.add('hidden');
            aiBrain.classList.add('thinking');
        } else {
            loader.hidden = true;
            responseArea.classList.remove('hidden');
            aiBrain.classList.remove('thinking');
        }
    }

    function showResponse(text, isError) {
        responseText.textContent = text;
        responseArea.classList.remove('hidden');
        
        if (isError) {
            responseArea.classList.add('error');
        } else {
            responseArea.classList.remove('error');
        }
    }

    async function sendMessage(userMessage) {
        if (isLoading) return;
        
        const cooldown = getCooldownRemaining();
        if (cooldown > 0) {
            showResponse('⏳ Espera ' + formatCooldown(cooldown) + ' segundos...', true);
            return;
        }
        
        conversationHistory.push({ role: 'user', content: userMessage });
        setLoading(true);
        lastMessageTime = Date.now();

        try {
            const response = await fetch(GROQ_URL, {
                method: 'POST',
                headers: {
                    'Authorization': 'Bearer ' + API_KEY,
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    model: 'llama-3.3-70b-versatile',
                    messages: [
                        { role: 'system', content: systemPrompt }
                    ].concat(conversationHistory),
                    max_tokens: 500,
                    temperature: 0.7
                })
            });

            setLoading(false);

            if (!response.ok) {
                if (response.status === 429) {
                    throw new Error('RATE_LIMIT');
                }
                let errorMsg = 'Error ' + response.status;
                try {
                    const errorData = await response.json();
                    if (errorData.error && errorData.error.message) {
                        errorMsg = errorData.error.message;
                    }
                } catch (e) {}
                throw new Error(errorMsg);
            }

            const data = await response.json();
            let botMessage = 'Lo siento, no pude procesar tu mensaje.';
            if (data.choices && data.choices[0] && data.choices[0].message && data.choices[0].message.content) {
                botMessage = data.choices[0].message.content;
            }
            
            conversationHistory.push({ role: 'assistant', content: botMessage });
            showResponse(botMessage, false);

        } catch (error) {
            setLoading(false);
            console.error('Chat error:', error);
            
            if (error.message === 'RATE_LIMIT') {
                lastMessageTime = Date.now() + 10000;
                showResponse('⏳ Límite alcanzado. Espera 10 segundos e intenta de nuevo.', true);
            } else {
                showResponse('😅 Algo salió mal. Intenta de nuevo o contáctame en nicolas@inadaptado.cl', true);
            }
            conversationHistory.pop();
        }
    }

    chatForm.addEventListener('submit', function(e) {
        e.preventDefault();
        const message = userInput.value.trim();
        if (!message || isLoading) return;
        
        userInput.value = '';
        sendMessage(message);
    });

    suggestionChips.forEach(function(chip) {
        chip.addEventListener('click', function() {
            const question = chip.getAttribute('data-question');
            if (question && !isLoading) {
                sendMessage(question);
            }
        });
    });
})();
</script>

<style>
    .chatbot-section {
        padding-bottom: 2rem;
    }

    .ai-assistant {
        background: linear-gradient(145deg, var(--color-light) 0%, #f8f8f8 100%);
        border-radius: 1.5rem;
        padding: 2rem 1.5rem;
        text-align: center;
        position: relative;
        overflow: hidden;
        box-shadow: 
            0 4px 24px rgba(0, 0, 0, 0.06),
            inset 0 1px 0 rgba(255, 255, 255, 0.8);
    }

    .ai-assistant::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, var(--color-primary), #ff6b6b, var(--color-primary));
        background-size: 200% 100%;
        animation: gradientMove 3s ease infinite;
    }

    @keyframes gradientMove {
        0%, 100% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
    }

    .ai-brain {
        position: relative;
        width: 80px;
        height: 80px;
        margin: 0 auto 1.5rem;
    }

    .brain-ring {
        position: absolute;
        inset: 0;
        border: 2px solid var(--color-primary);
        border-radius: 50%;
        opacity: 0.2;
    }

    .brain-ring:nth-child(1) {
        animation: pulse-ring 2s ease-out infinite;
    }

    .brain-ring:nth-child(2) {
        animation: pulse-ring 2s ease-out infinite 0.5s;
    }

    .brain-ring:nth-child(3) {
        animation: pulse-ring 2s ease-out infinite 1s;
    }

    .ai-brain.thinking .brain-ring {
        animation-duration: 0.8s;
        border-color: var(--color-primary);
        opacity: 0.4;
    }

    @keyframes pulse-ring {
        0% {
            transform: scale(0.8);
            opacity: 0.4;
        }
        100% {
            transform: scale(1.4);
            opacity: 0;
        }
    }

    .brain-core {
        position: absolute;
        inset: 15px;
        background: linear-gradient(135deg, var(--color-primary) 0%, #d32f2f 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 20px rgba(173, 0, 0, 0.3);
    }

    .brain-core svg {
        color: white;
    }

    .ai-brain.thinking .brain-core {
        animation: brain-pulse 0.6s ease-in-out infinite alternate;
    }

    @keyframes brain-pulse {
        from { transform: scale(1); }
        to { transform: scale(1.1); }
    }

    .ai-response-area {
        min-height: 100px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.5rem;
        transition: opacity 0.3s ease;
    }

    .ai-response-area.hidden {
        display: none;
    }

    .ai-response-area.error .ai-response {
        color: var(--color-primary);
    }

    .ai-response {
        font-size: 1rem;
        line-height: 1.7;
        color: var(--color-dark);
        max-width: 100%;
        animation: fadeIn 0.4s ease;
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .ai-loader {
        min-height: 100px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .ai-loader[hidden] {
        display: none;
    }

    .loader-dots {
        display: flex;
        gap: 8px;
    }

    .loader-dots span {
        width: 12px;
        height: 12px;
        background: var(--color-primary);
        border-radius: 50%;
        animation: bounce-loader 1.4s ease-in-out infinite;
    }

    .loader-dots span:nth-child(1) { animation-delay: 0s; }
    .loader-dots span:nth-child(2) { animation-delay: 0.2s; }
    .loader-dots span:nth-child(3) { animation-delay: 0.4s; }

    @keyframes bounce-loader {
        0%, 80%, 100% { 
            transform: scale(0.6);
            opacity: 0.4;
        }
        40% { 
            transform: scale(1);
            opacity: 1;
        }
    }

    .loader-text {
        font-size: 0.85rem;
        color: var(--color-dark-grey);
        animation: pulse-text 1.5s ease-in-out infinite;
    }

    @keyframes pulse-text {
        0%, 100% { opacity: 0.5; }
        50% { opacity: 1; }
    }

    .ai-suggestions {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.5rem;
        margin-bottom: 1.5rem;
        transition: opacity 0.3s ease;
    }

    .ai-suggestions.hidden {
        opacity: 0.3;
        pointer-events: none;
    }

    .suggestion-chip {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.5rem 1rem;
        background: white;
        border: 1px solid var(--color-light-grey);
        border-radius: 2rem;
        font-size: 0.85rem;
        color: var(--color-dark);
        cursor: pointer;
        transition: all 0.25s ease;
    }

    .suggestion-chip:hover {
        border-color: var(--color-primary);
        color: var(--color-primary);
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(173, 0, 0, 0.15);
    }

    .suggestion-chip:active {
        transform: translateY(0);
    }

    .chip-icon {
        font-size: 1rem;
    }

    .ai-input-wrapper {
        margin-bottom: 1rem;
    }

    .ai-input-container {
        display: flex;
        gap: 0.5rem;
        background: white;
        border: 2px solid var(--color-light-grey);
        border-radius: 3rem;
        padding: 0.35rem;
        transition: all 0.25s ease;
    }

    .ai-input-container:focus-within {
        border-color: var(--color-primary);
        box-shadow: 0 0 0 4px rgba(173, 0, 0, 0.1);
    }

    .ai-input-container input {
        flex: 1;
        padding: 0.7rem 1rem;
        border: none;
        background: transparent;
        font-size: 0.95rem;
        outline: none;
        color: var(--color-dark);
    }

    .ai-input-container input::placeholder {
        color: var(--color-light-grey);
    }

    .ai-input-container input:disabled {
        opacity: 0.5;
    }

    .ai-input-container button {
        flex-shrink: 0;
        width: 44px;
        height: 44px;
        border: none;
        border-radius: 50%;
        background: var(--color-primary);
        color: white;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.25s ease;
    }

    .ai-input-container button:hover:not(:disabled) {
        background: #8a0000;
        transform: scale(1.05);
    }

    .ai-input-container button:active:not(:disabled) {
        transform: scale(0.95);
    }

    .ai-input-container button:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .ai-footer {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        font-size: 0.75rem;
        color: var(--color-dark-grey);
    }

    .pulse-dot {
        width: 8px;
        height: 8px;
        background: #22c55e;
        border-radius: 50%;
        animation: pulse-dot 2s ease-in-out infinite;
    }

    @keyframes pulse-dot {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.5; transform: scale(0.8); }
    }

    @media (prefers-reduced-motion: reduce) {
        .brain-ring,
        .brain-core,
        .loader-dots span,
        .loader-text,
        .pulse-dot,
        .ai-response,
        .ai-assistant::before {
            animation: none;
        }
    }

    @media (max-width: 480px) {
        .ai-assistant {
            padding: 1.5rem 1rem;
        }

        .ai-brain {
            width: 60px;
            height: 60px;
        }

        .brain-core {
            inset: 10px;
        }

        .brain-core svg {
            width: 22px;
            height: 22px;
        }

        .ai-response {
            font-size: 0.95rem;
        }

        .suggestion-chip {
            padding: 0.4rem 0.8rem;
            font-size: 0.8rem;
        }
    }
</style>
