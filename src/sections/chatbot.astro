---
import nicoProfile from '../data/nico-profile.json';

const API_KEY = import.meta.env.PUBLIC_GROQ_API_KEY || '';
const profileData = JSON.stringify(nicoProfile);
---

<section id="ai-chat" class="history ai-oracle-section">
    <h2 class="heading">
        <svg
            xmlns="http://www.w3.org/2000/svg"
            width="40"
            height="40"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
        >
            <path d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z" />
            <path d="M18.25 6.5 18 7.5l-.25-1a2 2 0 0 0-1.25-1.25L15.5 5l1-.25a2 2 0 0 0 1.25-1.25L18 2.5l.25 1a2 2 0 0 0 1.25 1.25l1 .25-1 .25a2 2 0 0 0-1.25 1.25Z" />
        </svg>
        Pregunta lo que necesites
    </h2>

    <div class="oracle-container">
        <!-- Answer Card -->
        <div class="answer-card" id="answer-card">
            <div class="card-glow"></div>
            <div class="card-content">
                <div class="icon-wrapper" id="icon-wrapper">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/>
                        <path d="M12 16v-4"/>
                        <path d="M12 8h.01"/>
                    </svg>
                </div>
                <p class="answer-text" id="answer-text">
                    Escribe una pregunta sobre mi experiencia, habilidades o por qué deberías trabajar conmigo.
                </p>
            </div>
        </div>

        <!-- Quick Questions -->
        <div class="quick-questions" id="quick-questions">
            <button class="q-btn" data-q="¿Cuáles son tus principales fortalezas?">
                <span class="q-icon">💪</span>
                <span class="q-text">Fortalezas</span>
            </button>
            <button class="q-btn" data-q="¿Qué experiencia tienes con proyectos CRM?">
                <span class="q-icon">📊</span>
                <span class="q-text">CRM</span>
            </button>
            <button class="q-btn" data-q="¿Por qué debería contratarte?">
                <span class="q-icon">🚀</span>
                <span class="q-text">Contratar</span>
            </button>
            <button class="q-btn" data-q="¿Qué herramientas dominas?">
                <span class="q-icon">🛠️</span>
                <span class="q-text">Herramientas</span>
            </button>
        </div>

        <!-- Input Area -->
        <form class="oracle-input" id="oracle-form">
            <input 
                type="text" 
                id="oracle-input" 
                placeholder="Escribe tu pregunta aquí..."
                autocomplete="off"
            />
            <button type="submit" id="ask-btn" aria-label="Consultar">
                <span class="btn-text">Consultar</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"/>
                    <path d="m21 21-4.35-4.35"/>
                </svg>
            </button>
        </form>

        <p class="ai-badge">
            <span class="badge-dot"></span>
            Respuestas generadas por IA
        </p>
    </div>
</section>

<script is:inline define:vars={{ profileData, API_KEY }}>
(function() {
    const GROQ_URL = 'https://api.groq.com/openai/v1/chat/completions';
    const nicoProfile = JSON.parse(profileData);
    
    const systemPrompt = 'Eres Nico AI, la versión digital de Nicolás Gaitán. Tu objetivo es representarlo de manera auténtica, responder preguntas sobre su experiencia y convencer a potenciales clientes o empleadores de trabajar con él.\n\nINFORMACIÓN DE NICO:\n' + JSON.stringify(nicoProfile, null, 2) + '\n\nINSTRUCCIONES:\n- Responde en primera persona como si fueras Nico\n- Sé cercano, entusiasta y profesional\n- Destaca siempre los puntos fuertes y la propuesta de valor\n- Si preguntan por algo que no sabes, sugiere que contacten directamente a Nico\n- Respuestas concisas pero completas (máx 2-3 párrafos)\n- Usa emojis ocasionalmente para ser más cercano\n- Si preguntan por qué contratarlo, sé convincente pero genuino\n- Puedes recomendar que visiten inadaptado.cl o lo contacten directamente\n- Responde siempre en español a menos que te hablen en otro idioma';

    let conversationHistory = [];
    let isLoading = false;
    let lastMessageTime = 0;
    const COOLDOWN_MS = 2000;

    const answerCard = document.getElementById('answer-card');
    const answerText = document.getElementById('answer-text');
    const iconWrapper = document.getElementById('icon-wrapper');
    const oracleForm = document.getElementById('oracle-form');
    const oracleInput = document.getElementById('oracle-input');
    const askBtn = document.getElementById('ask-btn');
    const quickBtns = document.querySelectorAll('.q-btn');
    const quickQuestions = document.getElementById('quick-questions');

    function getCooldownRemaining() {
        const elapsed = Date.now() - lastMessageTime;
        return Math.max(0, COOLDOWN_MS - elapsed);
    }

    function setLoading(loading) {
        isLoading = loading;
        askBtn.disabled = loading;
        oracleInput.disabled = loading;
        
        if (loading) {
            answerCard.classList.add('loading');
            iconWrapper.innerHTML = '<div class="spinner"></div>';
            answerText.textContent = 'Analizando tu consulta...';
            quickQuestions.style.opacity = '0.3';
            quickQuestions.style.pointerEvents = 'none';
        } else {
            answerCard.classList.remove('loading');
            answerCard.classList.add('answered');
            iconWrapper.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>';
            quickQuestions.style.opacity = '1';
            quickQuestions.style.pointerEvents = 'auto';
        }
    }

    function showAnswer(text, isError) {
        answerText.textContent = text;
        answerCard.classList.add('revealed');
        
        if (isError) {
            answerCard.classList.add('error');
            iconWrapper.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/></svg>';
        } else {
            answerCard.classList.remove('error');
        }
    }

    async function askQuestion(question) {
        if (isLoading) return;
        
        const cooldown = getCooldownRemaining();
        if (cooldown > 0) {
            showAnswer('⏳ Espera ' + Math.ceil(cooldown / 1000) + ' segundos...', true);
            return;
        }
        
        conversationHistory.push({ role: 'user', content: question });
        setLoading(true);
        lastMessageTime = Date.now();

        try {
            const response = await fetch(GROQ_URL, {
                method: 'POST',
                headers: {
                    'Authorization': 'Bearer ' + API_KEY,
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    model: 'llama-3.3-70b-versatile',
                    messages: [
                        { role: 'system', content: systemPrompt }
                    ].concat(conversationHistory),
                    max_tokens: 500,
                    temperature: 0.7
                })
            });

            setLoading(false);

            if (!response.ok) {
                if (response.status === 429) {
                    throw new Error('RATE_LIMIT');
                }
                let errorMsg = 'Error ' + response.status;
                try {
                    const errorData = await response.json();
                    if (errorData.error && errorData.error.message) {
                        errorMsg = errorData.error.message;
                    }
                } catch (e) {}
                throw new Error(errorMsg);
            }

            const data = await response.json();
            let answer = 'Lo siento, no pude procesar tu pregunta.';
            if (data.choices && data.choices[0] && data.choices[0].message && data.choices[0].message.content) {
                answer = data.choices[0].message.content;
            }
            
            conversationHistory.push({ role: 'assistant', content: answer });
            showAnswer(answer, false);

        } catch (error) {
            setLoading(false);
            console.error('Oracle error:', error);
            
            if (error.message === 'RATE_LIMIT') {
                lastMessageTime = Date.now() + 10000;
                showAnswer('⏳ Demasiadas consultas. Espera 10 segundos.', true);
            } else {
                showAnswer('😅 Algo salió mal. Contáctame directamente en nicolas@inadaptado.cl', true);
            }
            conversationHistory.pop();
        }
    }

    oracleForm.addEventListener('submit', function(e) {
        e.preventDefault();
        const question = oracleInput.value.trim();
        if (!question || isLoading) return;
        
        oracleInput.value = '';
        askQuestion(question);
    });

    quickBtns.forEach(function(btn) {
        btn.addEventListener('click', function() {
            const question = btn.getAttribute('data-q');
            if (question && !isLoading) {
                askQuestion(question);
            }
        });
    });
})();
</script>

<style>
    .ai-oracle-section {
        padding-bottom: 2rem;
    }

    .oracle-container {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .answer-card {
        position: relative;
        min-height: 250px;
        background: linear-gradient(135deg, #ffffff 0%, #f8f8f8 100%);
        border-radius: 1.5rem;
        padding: 2rem;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
        border: 2px solid transparent;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        overflow: hidden;
    }

    .card-glow {
        position: absolute;
        inset: -2px;
        background: linear-gradient(135deg, var(--color-primary), #ff6b6b, var(--color-primary));
        background-size: 200% 200%;
        border-radius: 1.5rem;
        opacity: 0;
        z-index: -1;
        animation: gradientShift 3s ease infinite;
        transition: opacity 0.4s ease;
    }

    @keyframes gradientShift {
        0%, 100% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
    }

    .answer-card.loading .card-glow,
    .answer-card.answered .card-glow {
        opacity: 1;
    }

    .answer-card.revealed {
        transform: scale(1.02);
        box-shadow: 0 12px 48px rgba(173, 0, 0, 0.15);
    }

    .answer-card.error {
        background: linear-gradient(135deg, #fff5f5 0%, #ffe5e5 100%);
    }

    .card-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
        text-align: center;
    }

    .icon-wrapper {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, var(--color-primary), #d32f2f);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 8px 24px rgba(173, 0, 0, 0.25);
        transition: all 0.3s ease;
    }

    .answer-card.loading .icon-wrapper {
        animation: pulse-icon 1.5s ease-in-out infinite;
    }

    @keyframes pulse-icon {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.1); }
    }

    .icon-wrapper svg {
        color: white;
    }

    .spinner {
        width: 40px;
        height: 40px;
        border: 4px solid rgba(255, 255, 255, 0.3);
        border-top-color: white;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
        to { transform: rotate(360deg); }
    }

    .answer-text {
        font-size: 1.05rem;
        line-height: 1.7;
        color: var(--color-dark);
        max-width: 100%;
        animation: fadeIn 0.5s ease;
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .quick-questions {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 0.75rem;
        transition: opacity 0.3s ease;
    }

    .q-btn {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        padding: 1rem;
        background: white;
        border: 2px solid var(--color-light-grey);
        border-radius: 1rem;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .q-btn:hover {
        border-color: var(--color-primary);
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(173, 0, 0, 0.15);
    }

    .q-btn:active {
        transform: translateY(-2px);
    }

    .q-icon {
        font-size: 1.75rem;
    }

    .q-text {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--color-dark);
    }

    .oracle-input {
        display: flex;
        gap: 0.75rem;
        padding: 0.5rem;
        background: white;
        border: 2px solid var(--color-light-grey);
        border-radius: 3rem;
        transition: all 0.3s ease;
    }

    .oracle-input:focus-within {
        border-color: var(--color-primary);
        box-shadow: 0 0 0 4px rgba(173, 0, 0, 0.1);
    }

    .oracle-input input {
        flex: 1;
        padding: 0.75rem 1.25rem;
        border: none;
        background: transparent;
        font-size: 0.95rem;
        outline: none;
        color: var(--color-dark);
    }

    .oracle-input input::placeholder {
        color: var(--color-light-grey);
    }

    .oracle-input input:disabled {
        opacity: 0.6;
    }

    .oracle-input button {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        border: none;
        border-radius: 2rem;
        background: var(--color-primary);
        color: white;
        font-weight: 600;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.3s ease;
        white-space: nowrap;
    }

    .oracle-input button:hover:not(:disabled) {
        background: #8a0000;
        transform: scale(1.05);
    }

    .oracle-input button:active:not(:disabled) {
        transform: scale(0.98);
    }

    .oracle-input button:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .oracle-input button svg {
        width: 18px;
        height: 18px;
    }

    .ai-badge {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        font-size: 0.75rem;
        color: var(--color-dark-grey);
    }

    .badge-dot {
        width: 8px;
        height: 8px;
        background: var(--color-primary);
        border-radius: 50%;
        animation: pulse-dot 2s ease-in-out infinite;
    }

    @keyframes pulse-dot {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.4; }
    }

    @media (max-width: 640px) {
        .answer-card {
            min-height: 220px;
            padding: 1.5rem;
        }

        .icon-wrapper {
            width: 64px;
            height: 64px;
        }

        .icon-wrapper svg {
            width: 36px;
            height: 36px;
        }

        .answer-text {
            font-size: 0.95rem;
        }

        .quick-questions {
            grid-template-columns: repeat(2, 1fr);
            gap: 0.5rem;
        }

        .q-btn {
            padding: 0.75rem;
            gap: 0.35rem;
        }

        .q-icon {
            font-size: 1.5rem;
        }

        .q-text {
            font-size: 0.75rem;
        }

        .oracle-input button .btn-text {
            display: none;
        }

        .oracle-input button {
            padding: 0.75rem 1rem;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .card-glow,
        .icon-wrapper,
        .answer-card,
        .badge-dot {
            animation: none;
        }
    }
</style>
