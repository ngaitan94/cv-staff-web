# Copia este archivo a .env y añade tus API keys

# Groq API Key para el chatbot AI
# Obtén tu key en: https://console.groq.com/keys
PUBLIC_GROQ_API_KEY=tu_api_key_aqui

# Neon Database URL para almacenar logs del chatbot
# Obtén tu connection string en: https://console.neon.tech
# Formato: postgresql://[user]:[password]@[host]/[database]?sslmode=require
DATABASE_URL=tu_database_url_aqui
